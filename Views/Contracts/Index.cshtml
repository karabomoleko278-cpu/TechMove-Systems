@model TechMoveSystems.ViewModels.ContractListViewModel
@using TechMoveSystems.Models
@{
    ViewData["Title"] = "Contracts";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Contracts</p>
        <h1>View and manage all your client contracts.</h1>
        <p>Filter by date range or status to find the contract you need.</p>
    </div>
    <a class="btn btn-primary btn-pill" asp-action="Create">Add Contract</a>
</section>

<section class="table-shell">
    <form method="get" class="filter-bar">
        <div>
            <label class="form-label" for="startDate">Start from</label>
            <input class="form-control" id="startDate" name="startDate" type="date" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label" for="endDate">End by</label>
            <input class="form-control" id="endDate" name="endDate" type="date" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div>
            <label class="form-label" for="status">Status</label>
            <select class="form-select" id="status" name="status" asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()">
                <option value="">All statuses</option>
            </select>
        </div>
        <div class="d-flex align-items-end">
            <button class="btn btn-primary btn-pill w-100" type="submit">Apply Filters</button>
        </div>
    </form>

    @if (Model.Contracts.Any())
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Region</th>
                    <th>Service level</th>
                    <th>Contract term</th>
                    <th>Status</th>
                    <th>Requests</th>
                    <th>Agreement</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model.Contracts)
                {
                    <tr>
                        <td>
                            <strong>@contract.Client?.Name</strong>
                            <div>@contract.Client?.ContactDetails</div>
                        </td>
                        <td>@contract.Client?.Region</td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("dd MMM yyyy") - @contract.EndDate.ToString("dd MMM yyyy")</td>
                        <td><span class="status-chip status-chip--@contract.Status.ToString().ToLowerInvariant()">@contract.Status</span></td>
                        <td>@contract.ServiceRequests.Count</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(contract.SignedAgreementPath))
                            {
                                <a asp-action="DownloadAgreement" asp-route-id="@contract.Id">Download PDF</a>
                            }
                            else
                            {
                                <span class="text-muted">No file</span>
                            }
                        </td>
                        <td>
                            <form method="post" asp-action="Delete" asp-route-id="@contract.Id"
                                  onsubmit="return confirm('Delete this contract and its client? This cannot be undone.');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger btn-pill" style="padding:0.45rem 0.9rem;font-size:0.82rem;">
                                    Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state empty-state--action">
            <strong>No contracts match the current filter.</strong>
            <p>Create a contract first so service requests have a valid parent workflow.</p>
            <a class="btn btn-primary btn-pill" asp-action="Create">Create Contract</a>
        </div>
    }
</section>
