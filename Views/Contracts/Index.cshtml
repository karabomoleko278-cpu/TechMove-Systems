@model TechMoveSystems.ViewModels.ContractListViewModel
@using TechMoveSystems.Models
@{
    ViewData["Title"] = "Contracts";
}

<div class="container mt-5">
    <h1>Contracts List</h1>
    <a class="btn btn-primary mb-3" asp-action="Create">Add Contract</a>

    <form method="get" class="row mb-4">
        <div class="col-md-3">
            <label>Start Date</label>
            <input class="form-control" name="startDate" type="date" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3">
            <label>End Date</label>
            <input class="form-control" name="endDate" type="date" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-md-3">
            <label>Status</label>
            <select class="form-control" name="status" asp-for="Status" asp-items="Html.GetEnumSelectList<ContractStatus>()">
                <option value="">All statuses</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-secondary w-100" type="submit">Filter</button>
        </div>
    </form>

    @if (Model.Contracts.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Region</th>
                    <th>Service level</th>
                    <th>Contract term</th>
                    <th>Status</th>
                    <th>Requests</th>
                    <th>Agreement</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contract in Model.Contracts)
                {
                    <tr>
                        <td>
                            @contract.Client?.Name<br/>
                            <small>@contract.Client?.ContactDetails</small>
                        </td>
                        <td>@contract.Client?.Region</td>
                        <td>@contract.ServiceLevel</td>
                        <td>@contract.StartDate.ToString("yyyy-MM-dd") to @contract.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>@contract.Status</td>
                        <td>@contract.ServiceRequests.Count</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(contract.SignedAgreementPath))
                            {
                                <a asp-action="DownloadAgreement" asp-route-id="@contract.Id">Download</a>
                            }
                        </td>
                        <td>
                            <form method="post" asp-action="Delete" asp-route-id="@contract.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No contracts found.</p>
    }
</div>
