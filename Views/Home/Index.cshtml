@model TechMoveSystems.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "System Overview";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1>Welcome to the System</h1>
            <p class="lead">Please review the current system data below and apply the necessary UI styling.</p>
            <hr />
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Active Contracts</h5>
                    <p class="card-text fs-3">@Model.ActiveContractCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Total Requests</h5>
                    <p class="card-text fs-3">@Model.RequestCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Live USD/ZAR Rate</h5>
                    <p class="card-text fs-3">@Model.LatestExchangeRate.ToString("0.00")</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6">
            <h2>Contracts Needing Review</h2>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Status</th>
                        <th>End Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.ContractsRequiringAttention.Any())
                    {
                        foreach(var contract in Model.ContractsRequiringAttention)
                        {
                            <tr>
                                <td>@contract.Client?.Name</td>
                                <td>@contract.Status</td>
                                <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3">No contracts require attention.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="col-md-6">
            <h2>Recent Service Requests</h2>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Cost (ZAR)</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.RecentRequests.Any())
                    {
                        foreach(var req in Model.RecentRequests)
                        {
                            <tr>
                                <td>@req.Description</td>
                                <td>@req.CostZar.ToString("N2")</td>
                                <td>@req.Status</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3">No recent requests.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
