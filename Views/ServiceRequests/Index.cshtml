@model IEnumerable<TechMoveSystems.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-5">
    <h1>Service Requests</h1>
    <a class="btn btn-primary mb-3" asp-action="Create">Add Request</a>

    @if (Model.Any())
    {
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Status</th>
                    <th>USD</th>
                    <th>Rate</th>
                    <th>ZAR</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>@request.Contract?.Client?.Name</td>
                        <td>@request.Description</td>
                        <td>@request.Status</td>
                        <td>@request.CostUsd.ToString("N2")</td>
                        <td>@request.ExchangeRate.ToString("0.0000")</td>
                        <td>@request.CostZar.ToString("N2")</td>
                        <td>@request.CreatedAt.ToString("yyyy-MM-dd")</td>
                        <td>
                            <form method="post" asp-action="Delete" asp-route-id="@request.Id">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No service requests found.</p>
    }
</div>
