@model TechMoveSystems.ViewModels.ServiceRequestCreateViewModel
@using TechMoveSystems.Models
@using System.Globalization
@{
    ViewData["Title"] = "New Request";
}

<div class="container mt-5">
    <h1>Create Service Request</h1>
    
    <form method="post" asp-action="Create">
        @Html.AntiForgeryToken()
        
        <div class="mb-3">
            <label asp-for="ContractId" class="form-label"></label>
            <select asp-for="ContractId" class="form-control" asp-items="Model.Contracts">
                <option value="">Select Contract</option>
            </select>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <input asp-for="Description" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="CostUsd" class="form-label"></label>
            <input asp-for="CostUsd" class="form-control" id="usdAmount" type="number" step="0.01" />
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<RequestStatus>()"></select>
        </div>
        
        <input type="hidden" name="ExchangeRate" value="@Model.ExchangeRate.ToString(CultureInfo.InvariantCulture)" />
        <input type="hidden" name="CostZar" id="zarHidden" value="@Model.CostZar.ToString(CultureInfo.InvariantCulture)" />

        <button class="btn btn-primary" type="submit">Submit</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
